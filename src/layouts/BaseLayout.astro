---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  locale?: 'en' | 'pt';
}

const { title = 'Lucas Barbosa — Front-End Engineer', description = 'Vue.js engineer, 7 years shipping health tech at scale. Portfolio of Lucas Barbosa do Nascimento.', locale = 'en' } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F8F7F4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
