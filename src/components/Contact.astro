---
export interface Props {
  t: {
    contact: { num: string; title: string; titleEm: string; email: string; github: string; linkedin: string };
  };
  locale: 'en' | 'pt';
}

const { t, locale } = Astro.props;
---

<section class="section container contact" id="contact">
  <div class="section-num">{t.contact.num}</div>
  <h2 class="section-title contact-title">{t.contact.title} <em>{t.contact.titleEm}</em></h2>

  <div class="contact-links">
    <a href="mailto:lucas.barbosa.nas@gmail.com">
      <span class="label">{t.contact.email}</span>
      <span class="handle">lucas.barbosa.nas@gmail.com</span>
    </a>
    <a href="https://github.com/lucasn4s" target="_blank" rel="noopener noreferrer">
      <span class="label">{t.contact.github}</span>
      <span class="handle">@lucasn4s</span>
    </a>
    <a href="https://www.linkedin.com/in/lucasn4s/" target="_blank" rel="noopener noreferrer">
      <span class="label">{t.contact.linkedin}</span>
      <span class="handle">Lucas Nascimento</span>
    </a>
  </div>
</section>
